    dealRewardRatio: 0
    blocksEvents: 0
    requiredSkills: []
    statConditions: []
  - displayName: Deal and Betray the Nation
    description: Accept the oil deal, end the war. Your political influence drops
      and suspicion rises, but you secure a massive guaranteed share.
    supportModifier: 0
    suspicionModifier: 5
    politicalInfluenceModifier: -10
    costModifier: 0
    endsWar: 0
    warEndDelay: 0
